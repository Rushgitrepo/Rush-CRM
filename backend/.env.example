# Server Configuration
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:8080

# Database - Local PostgreSQL
DATABASE_URL=postgres://postgres:password@localhost:5432/CRM

# JWT Secret - Generate a secure random string
JWT_SECRET=your_jwt_secret_here

# Google 
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

GOOGLE_REDIRECT_URI=http://localhost:4000/api/email/oauth-callback
GOOGLE_CALENDER_REDIRECT_URI=http://localhost:4000/api/calendar/auth/google/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:4000/api/drive/oauth-callback

# Apple Redirect 
APPLE_EMAIL=your_apple_email@example.com
APPLE_Password=your_apple_app_specific_password
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993

# Microsoft Config 
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:4000/api/calendar/auth/microsoft/callback

# Email Configuration
# SMTP Configuration (Gmail, Outlook, Custom SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_smtp_app_password

# RingCentral Official API
RC_CLIENT_ID=your_rc_client_id
RC_CLIENT_SECRET=your_rc_client_secret
RC_SERVER_URL=https://platform.ringcentral.com
RC_REDIRECT_URI=http://localhost:4000/api/ringcentral/callback

# Instantly.ai Integration
INSTANTLY_API_KEY=your_instantly_api_key
INSTANTLY_WEBHOOK_SECRET=your_instantly_webhook_secret

# Backend public URL (used for absolute avatar URLs in push notifications)
BACKEND_URL=http://localhost:4000

# VAPID KEYS FOR PUSH 
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# TURN Server (for WebRTC NAT traversal)
TURN_USERNAME=rushcrm
TURN_CREDENTIAL=your_turn_credential_here

# Firebase Cloud Messaging (FCM)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Fallback (optional)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key

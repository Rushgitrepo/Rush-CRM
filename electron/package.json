{
  "name": "rush-crm-desktop",
  "version": "1.0.56",
  "description": "Rush CRM Desktop Application",
  "main": "main.js",
  "author": "Jawad Abbas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jawa090/Rush-CRM.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "electron-builder --publish=never",
    "build:win": "electron-builder --win --publish=never",
    "build:mac": "electron-builder --mac --publish=never",
    "build:win:publish": "electron-builder --win --publish always",
    "build:mac:publish": "electron-builder --mac --publish always",
    "build:linux": "electron-builder --linux --publish=never",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.rushcrm.desktop",
    "productName": "Rush CRM",
    "copyright": "Copyright © 2024",
    "electronDownload": {
      "cache": "./cache"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "autoUpdater.js",
      "preload.js",
      "assets/**/*",
      "../frontend/dist/**/*",
      "../frontend/public/crm3.png"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "../frontend/public/crm3.png",
        "to": "crm3.png"
      }
    ],
    "extraFiles": [
      {
        "from": "../frontend/public/crm3.png",
        "to": "assets/crm3.png"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Jawa090",
      "repo": "Rush-CRM",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../frontend/public/crm3.png",
      "artifactName": "Rush-CRM-Setup-${version}.${ext}",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Rush CRM",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "differentialPackage": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "Rush-CRM-${version}-${arch}.${ext}",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": "-"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "../frontend/public/crm3.png",
      "category": "Office"
    }
  }
}
